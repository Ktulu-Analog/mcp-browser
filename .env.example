# Configuration optionnelle du serveur MCP Browser
# Copiez ce fichier en .env et adaptez les valeurs

# Port d'écoute (défaut: 6503)
# MCP_PORT=6503

# URL du service FlareSolverr (optionnel — résolution challenges Cloudflare)
# Décommentez si vous utilisez docker-compose avec FlareSolverr
# FLARESOLVERR_URL=http://flaresolverr:8191/v1

# Fichier de persistance des cookies CF (optionnel)
# Nécessite un volume Docker ou un répertoire accessible en écriture
# COOKIE_FILE=/data/cookies.json

# Mode headless Playwright : true = sans fenêtre (serveur), false = avec fenêtre (debug local)
# BROWSER_HEADLESS=true
